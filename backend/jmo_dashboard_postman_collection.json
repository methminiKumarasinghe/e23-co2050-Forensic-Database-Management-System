{
	"info": {
		"_postman_id": "4b68e9f2-28df-4a6c-947b-1a9fc55d8f28",
		"name": "JMO Dashboard API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Module 1 - Dashboard",
			"item": [
				{
					"name": "Get Dashboard Stats",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jmo_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/jmo/dashboard",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"jmo",
								"dashboard"
							]
						}
					}
				}
			]
		},
		{
			"name": "Module 2 - Assigned MLEF Requests",
			"item": [
				{
					"name": "Get MLEF Requests",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jmo_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/jmo/mlef?status=PENDING",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"jmo",
								"mlef"
							],
							"query": [
								{
									"key": "status",
									"value": "PENDING"
								}
							]
						}
					}
				},
				{
					"name": "Get MLEF by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jmo_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/jmo/mlef/{{mlef_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"jmo",
								"mlef",
								"{{mlef_id}}"
							]
						}
					}
				}
			]
		},
		{
			"name": "Module 3 - Medical Examination",
			"item": [
				{
					"name": "Get Examinations",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jmo_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/jmo/examinations",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"jmo",
								"examinations"
							]
						}
					}
				},
				{
					"name": "Create Examination",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jmo_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mlef_id\": \"{{mlef_id}}\",\n  \"examination_date\": \"2024-01-01T10:00:00Z\",\n  \"examination_notes\": \"General exam notes...\",\n  \"conclusion\": \"Initial review completed.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/jmo/examinations",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"jmo",
								"examinations"
							]
						}
					}
				},
				{
					"name": "Update Examination",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jmo_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status_id\": 2,\n  \"conclusion\": \"Updated conclusion...\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/jmo/examinations/{{examination_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"jmo",
								"examinations",
								"{{examination_id}}"
							]
						}
					}
				}
			]
		},
		{
			"name": "Module 11 - Medico-Legal Reports",
			"item": [
				{
					"name": "Create Report",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jmo_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"examination_id\": \"{{examination_id}}\",\n  \"findings\": \"All clear.\",\n  \"medical_opinion\": \"No significant issues.\",\n  \"recommendations\": \"Rest for 3 days.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/jmo/reports",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"jmo",
								"reports"
							]
						}
					}
				},
				{
					"name": "Sign Report",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jmo_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"signature_hash\": \"generated_hash_string_here\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/jmo/reports/{{report_id}}/sign",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"jmo",
								"reports",
								"{{report_id}}",
								"sign"
							]
						}
					}
				}
			]
		},
		{
			"name": "Module 14 - Search",
			"item": [
				{
					"name": "Search Examinations",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jmo_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/jmo/search?q=John",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"jmo",
								"search"
							],
							"query": [
								{
									"key": "q",
									"value": "John"
								}
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5000"
		},
		{
			"key": "jmo_token",
			"value": "YOUR_JWT_TOKEN_HERE"
		},
		{
			"key": "mlef_id",
			"value": ""
		},
		{
			"key": "examination_id",
			"value": ""
		},
		{
			"key": "report_id",
			"value": ""
		}
	]
}
