{
	"info": {
		"_postman_id": "7a35e9f2-28df-4a6c-947b-1a9fc55d8f76",
		"name": "Laboratory Dashboard API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Module 1 - Dashboard",
			"item": [
				{
					"name": "Get Dashboard Stats",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{lab_tech_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/laboratory/dashboard",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"laboratory",
								"dashboard"
							]
						}
					}
				}
			]
		},
		{
			"name": "Module 2 - Requests",
			"item": [
				{
					"name": "Get Requests",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{lab_tech_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/laboratory/requests?status=PENDING",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"laboratory",
								"requests"
							],
							"query": [
								{
									"key": "status",
									"value": "PENDING"
								}
							]
						}
					}
				},
				{
					"name": "Get Request By ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{lab_tech_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/laboratory/requests/{{request_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"laboratory",
								"requests",
								"{{request_id}}"
							]
						}
					}
				}
			]
		},
		{
			"name": "Module 3 - Accept/Reject Request",
			"item": [
				{
					"name": "Accept Request",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{lab_tech_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"ACCEPTED\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/laboratory/requests/{{request_id}}/status",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"laboratory",
								"requests",
								"{{request_id}}",
								"status"
							]
						}
					}
				}
			]
		},
		{
			"name": "Module 5 & 8 - Tests",
			"item": [
				{
					"name": "Create Test",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{lab_tech_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"request_id\": \"{{request_id}}\",\n  \"test_name\": \"Blood Toxicology\",\n  \"test_category\": \"Toxicology\",\n  \"expected_completion_date\": \"2024-05-20\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/laboratory/tests",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"laboratory",
								"tests"
							]
						}
					}
				},
				{
					"name": "Complete Test",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{lab_tech_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/laboratory/tests/{{test_id}}/complete",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"laboratory",
								"tests",
								"{{test_id}}",
								"complete"
							]
						}
					}
				}
			]
		},
		{
			"name": "Module 6 & 7 - Results & Files",
			"item": [
				{
					"name": "Create Result",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{lab_tech_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"test_id\": \"{{test_id}}\",\n  \"findings\": \"Positive for substance X\",\n  \"interpretation\": \"Requires further review\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/laboratory/results",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"laboratory",
								"results"
							]
						}
					}
				},
				{
					"name": "Upload Attachment",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{lab_tech_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "attachment",
									"type": "file",
									"src": ""
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/laboratory/results/{{result_id}}/files",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"laboratory",
								"results",
								"{{result_id}}",
								"files"
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5000"
		},
		{
			"key": "lab_tech_token",
			"value": "YOUR_JWT_TOKEN_HERE"
		},
		{
			"key": "request_id",
			"value": ""
		},
		{
			"key": "test_id",
			"value": ""
		},
		{
			"key": "result_id",
			"value": ""
		}
	]
}
